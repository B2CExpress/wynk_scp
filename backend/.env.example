# --- App ---
NODE_ENV=development
PORT=3001

# --- Database (Postgres) ---
# Portas alinhadas com docker-compose.yml na raiz (5435/6382 expostas no host
# pra evitar conflito com wynk_ecommerce 5434/6381 rodando em paralelo).
DB_HOST=localhost
DB_PORT=5435
DB_USER=scp
DB_PASS=scp
DB_NAME=scp
DB_SCHEMA=scp

# --- Redis ---
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- Cache ---
CACHE_TTL_TENANT_SECONDS=600

# --- JWT ---
# OBRIGATÓRIO em production. Gerar com: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- Cookie ---
# COOKIE_DOMAIN=.scp.local

# --- Seed ---
# Senha do admin criado pelo `npm run seed`. Obrigatória em production.
SEED_ADMIN_PASSWORD=admin123

# --- TypeORM ---
# TYPEORM_LOGGING=true
